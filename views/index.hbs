
    <section><div class="container mt-5">
        <div class="row">
            {{#each products}}
          <div class="col-md-3">
            <div class="card" style="width:18em;">
              <img
                src="{{this.image}}"
                class="card-img-top"
                alt="{{this.name}}"
              />
              <div class="card-body">
                <h5 class="card-title">{{this.name}}</h5>
                <p class="card-text">{{this.description}}</p>
                <a href="#" class="btn btn-primary">Order now!!</a>
              </div>
            </div>
              {{/each}}
          </div>
        </div>
      </div>
    </section>

   